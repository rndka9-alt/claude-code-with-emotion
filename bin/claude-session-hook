#!/usr/bin/env node

const fs = require("node:fs");
const { dirname, join } = require("node:path");
const { spawnSync } = require("node:child_process");
const { getHelperBinFilename } = require("./lib/helper-bin-resolver");

function appendTrace(message) {
  const traceFilePath = process.env.CLAUDE_WITH_EMOTION_TRACE_FILE;

  if (typeof traceFilePath !== "string" || traceFilePath.length === 0) {
    return;
  }

  const line = `[${new Date().toISOString()}] [claude-session-hook] ${message}\n`;

  try {
    fs.appendFileSync(traceFilePath, line, "utf8");
  } catch {
    // Ignore trace write failures inside the hook helper.
  }
}

function readStdinText() {
  try {
    return fs.readFileSync(0, "utf8").trim();
  } catch {
    return "";
  }
}

function parsePayload(text) {
  if (text.length === 0) {
    return null;
  }

  try {
    const parsed = JSON.parse(text);

    if (typeof parsed === "object" && parsed !== null) {
      return parsed;
    }
  } catch {
    appendTrace(`failed to parse hook payload text=${text}`);
  }

  return null;
}

function readStringField(payload, keys) {
  if (typeof payload !== "object" || payload === null) {
    return null;
  }

  for (const key of keys) {
    const value = payload[key];

    if (typeof value === "string" && value.length > 0) {
      return value;
    }
  }

  return null;
}

function readBooleanField(payload, keys) {
  if (typeof payload !== "object" || payload === null) {
    return null;
  }

  for (const key of keys) {
    const value = payload[key];

    if (typeof value === "boolean") {
      return value;
    }

    if (typeof value === "string") {
      if (value === "true") {
        return true;
      }

      if (value === "false") {
        return false;
      }
    }
  }

  return null;
}

function summarizeText(text, fallback, prefix) {
  if (typeof text !== "string") {
    return fallback;
  }

  const singleLine = text.replace(/\s+/g, " ").trim();

  if (singleLine.length === 0) {
    return fallback;
  }

  const normalizedText =
    singleLine.length > 80 ? `${singleLine.slice(0, 77)}...` : singleLine;

  return `${prefix}${normalizedText}`;
}

function summarizePrompt(payload) {
  return summarizeText(
    readStringField(payload, ["prompt", "user_prompt", "input", "message"]),
    "Reviewing the latest user prompt",
    "Prompt: ",
  );
}

function summarizeTool(payload, fallback) {
  const toolName = readStringField(payload, [
    "tool_name",
    "toolName",
    "tool",
    "name",
  ]);

  if (typeof toolName !== "string") {
    return fallback;
  }

  return `${fallback} (${toolName})`;
}

function summarizePermission(payload) {
  const toolName = readStringField(payload, [
    "tool_name",
    "toolName",
    "tool",
    "name",
  ]);

  if (typeof toolName === "string") {
    return `Waiting on permission for ${toolName}`;
  }

  return summarizeText(
    readStringField(payload, ["message", "reason", "description"]),
    "Waiting on permission approval",
    "Permission: ",
  );
}

function summarizeNotification(payload) {
  return summarizeText(
    readStringField(payload, [
      "message",
      "title",
      "content",
      "text",
      "notification",
    ]),
    "Reviewing a Claude notification",
    "Notification: ",
  );
}

function summarizePermissionCancellation(pendingPermission) {
  if (
    typeof pendingPermission === "object" &&
    pendingPermission !== null &&
    typeof pendingPermission.task === "string" &&
    pendingPermission.task.length > 0
  ) {
    return `${pendingPermission.task} (not approved)`;
  }

  return "Permission was not approved";
}

function summarizeElicitation(payload) {
  return summarizeText(
    readStringField(payload, ["question", "prompt", "message", "text"]),
    "Waiting for additional input",
    "Need input: ",
  );
}

// 공용 summary 로, Subagent* / TeammateIdle / TaskCompleted 에서 함께 호출된다.
// 각 이벤트의 실제 페이로드 필드를 함께 나열한다:
//  - TaskCompleted: task_subject(요약), task_description(상세, optional)
//  - SubagentStop: last_assistant_message, agent_type, agent_id
//  - SubagentStart: agent_type, agent_id
function summarizeBackgroundTask(payload, fallback) {
  return summarizeText(
    readStringField(payload, [
      "task_subject",
      "task_description",
      "last_assistant_message",
      "agent_type",
      "agent_id",
    ]),
    fallback,
    "Task: ",
  );
}

// Claude Code 의 Notification 훅 페이로드는 notification_type 필드로 종류를 구분한다
// (permission_prompt / idle_prompt / auth_success / elicitation_dialog).
// 과거엔 notification/type/subtype 를 추정으로 읽엇는데 실제 필드명과 달라서
// 권한 팝업이 항상 surprised 폴백으로 새던 버그가 잇엇다.
function isPermissionPromptNotification(payload) {
  const notificationType = readStringField(payload, ["notification_type"]);

  return notificationType === "permission_prompt";
}

function isToolInterrupt(payload) {
  return readBooleanField(payload, ["is_interrupt"]) === true;
}

function getHookStateFilePath() {
  const hookStateFilePath = process.env.CLAUDE_WITH_EMOTION_HOOK_STATE_FILE;

  if (typeof hookStateFilePath !== "string" || hookStateFilePath.length === 0) {
    return null;
  }

  return hookStateFilePath;
}

function readHookState() {
  const hookStateFilePath = getHookStateFilePath();

  if (hookStateFilePath === null) {
    return {};
  }

  try {
    const text = fs.readFileSync(hookStateFilePath, "utf8");
    const parsed = JSON.parse(text);

    if (typeof parsed === "object" && parsed !== null) {
      return parsed;
    }
  } catch (error) {
    if (error instanceof Error && error.name !== "ENOENT") {
      appendTrace(`failed to read hook state file error=${error.message}`);
    }
  }

  return {};
}

function writeHookState(nextState) {
  const hookStateFilePath = getHookStateFilePath();

  if (hookStateFilePath === null) {
    return;
  }

  try {
    fs.mkdirSync(dirname(hookStateFilePath), { recursive: true });
    fs.writeFileSync(
      hookStateFilePath,
      JSON.stringify(nextState, null, 2),
      "utf8",
    );
  } catch (error) {
    if (error instanceof Error) {
      appendTrace(`failed to write hook state file error=${error.message}`);
    }
  }
}

function getPendingPermission(hookState) {
  if (typeof hookState !== "object" || hookState === null) {
    return null;
  }

  const pendingPermission = hookState.pendingPermission;

  if (typeof pendingPermission !== "object" || pendingPermission === null) {
    return null;
  }

  return pendingPermission;
}

function buildNextHookState(eventName, payload, hookState) {
  const nextState = {
    ...hookState,
    lastEvent: eventName,
  };

  if (
    eventName === "PermissionRequest" ||
    (eventName === "Notification" && isPermissionPromptNotification(payload))
  ) {
    nextState.pendingPermission = {
      task: summarizePermission(payload),
      toolName:
        readStringField(payload, ["tool_name", "toolName", "tool", "name"]) ??
        "",
      requestedAt: new Date().toISOString(),
    };
    return nextState;
  }

  if (
    eventName === "UserPromptSubmit" ||
    eventName === "PermissionDenied" ||
    eventName === "PreToolUse" ||
    eventName === "PostToolUse" ||
    eventName === "PostToolUseFailure" ||
    eventName === "Stop" ||
    eventName === "StopFailure" ||
    eventName === "SessionEnd"
  ) {
    delete nextState.pendingPermission;
    return nextState;
  }

  return nextState;
}

function describePayloadForTrace(payload) {
  if (typeof payload !== "object" || payload === null) {
    return "none";
  }

  const selectedEntries = Object.entries(payload).filter((entry) => {
    const key = entry[0];
    const value = entry[1];

    if (
      key === "reason" ||
      key === "stop_reason" ||
      key === "stopReason" ||
      key === "last_assistant_message" ||
      key === "tool_name" ||
      key === "type" ||
      key === "subtype" ||
      key === "notification" ||
      key === "prompt" ||
      key === "message"
    ) {
      return typeof value === "string" && value.length > 0;
    }

    if (key === "is_interrupt") {
      return typeof value === "boolean";
    }

    return false;
  });

  if (selectedEntries.length === 0) {
    return "none";
  }

  return selectedEntries
    .map(([key, value]) => {
      return `${key}=${String(value).replace(/\s+/g, " ").slice(0, 140)}`;
    })
    .join(" | ");
}

function createUpdate(eventName, payload, hookState) {
  const pendingPermission = getPendingPermission(hookState);

  if (eventName === "SessionStart") {
    return {
      activity: "다음 입력 기다리는 중",
      state: "waiting",
      line: "Claude 연결 완료! 다음 입력을 기다리고 잇어요...!",
      task: "Waiting for the next prompt",
      intensity: "low",
    };
  }

  if (eventName === "UserPromptSubmit") {
    return {
      activity:
        pendingPermission === null
          ? "자료를 찾는 중"
          : "새 입력을 다시 살피는 중",
      state: "thinking",
      line:
        pendingPermission === null
          ? "질문 읽고 흐름 잡는 중이에요...!"
          : "권한 승인 없이 넘어와서 새 입력을 읽는 중이에요...!",
      task: summarizePrompt(payload),
      intensity: "medium",
    };
  }

  if (eventName === "PermissionRequest") {
    return {
      activity: "권한 확인 기다리는 중",
      state: "permission_wait",
      line: "권한 확인 기다리는 중이에요...!",
      task: summarizePermission(payload),
      intensity: "medium",
    };
  }

  if (eventName === "PermissionDenied") {
    return {
      activity: "우회 경로를 찾는 중",
      // state·emotion 분리 emit: 베이스 lifecycle 은 waiting(권한 막혀 멈춤),
      // 감정 색칠만 sad 로 올린다. 레거시 "sad" 숏컷 토큰은 호환용으로만 남겨둠.
      state: "waiting",
      emotion: "sad",
      line: "권한이 막혀서 다른 길 찾는 중이에요...!",
      task: summarizePermission(payload),
      intensity: "medium",
    };
  }

  if (eventName === "PreToolUse") {
    return {
      activity: "컴퓨터 작업중",
      state: "working",
      line: "도구를 써서 확인하는 중이에요...!",
      task: summarizeTool(payload, "Using a Claude tool"),
      intensity: "medium",
    };
  }

  if (eventName === "PostToolUse") {
    return {
      activity: "결과를 정리하는 중",
      state: "thinking",
      line: "방금 가져온 결과를 정리 중이에요...!",
      task: summarizeTool(payload, "Reviewing tool output"),
      intensity: "medium",
    };
  }

  if (eventName === "Notification") {
    if (isPermissionPromptNotification(payload)) {
      return {
        activity: "권한 확인 기다리는 중",
        state: "permission_wait",
        line: "권한 팝업 확인 중이에요...!",
        task: summarizePermission(payload),
        intensity: "medium",
      };
    }

    return {
      activity: "새 알림 확인 중",
      // state·emotion 분리 emit: 베이스 lifecycle 은 waiting(외부 이벤트 관찰),
      // 감정 색칠만 surprised 로 올린다.
      state: "waiting",
      emotion: "surprised",
      line: "새 알림이 와서 확인 중이에요...!",
      task: summarizeNotification(payload),
      intensity: "medium",
    };
  }

  if (eventName === "Elicitation") {
    return {
      activity: "추가 입력 기다리는 중",
      state: "waiting",
      line: "추가 입력을 기다리고 잇어요...!",
      task: summarizeElicitation(payload),
      intensity: "medium",
    };
  }

  if (eventName === "ElicitationResult") {
    return {
      activity: "추가 입력 반영 중",
      state: "thinking",
      line: "방금 받은 입력을 반영 중이에요...!",
      task: summarizeElicitation(payload),
      intensity: "medium",
    };
  }

  if (eventName === "SubagentStart") {
    return {
      activity: "보조 작업 진행 중",
      state: "working",
      line: "보조 작업을 함께 진행 중이에요...!",
      task: summarizeBackgroundTask(payload, "Coordinating background work"),
      intensity: "medium",
    };
  }

  if (eventName === "SubagentStop") {
    return {
      activity: "보조 작업 결과 정리 중",
      state: "thinking",
      line: "추가 작업 결과를 정리 중이에요...!",
      task: summarizeBackgroundTask(
        payload,
        "Reviewing background task output",
      ),
      intensity: "medium",
    };
  }

  if (eventName === "TeammateIdle") {
    return {
      activity: "다음 지시 기다리는 중",
      state: "waiting",
      line: "보조 작업이 다음 지시를 기다리고 잇어요...!",
      task: summarizeBackgroundTask(payload, "Waiting on background work"),
      intensity: "low",
    };
  }

  if (eventName === "TaskCreated") {
    return {
      activity: "새 작업 시작",
      state: "working",
      line: "새 작업을 하나 시작햇어요...!",
      task: summarizeBackgroundTask(payload, "Background task started"),
      intensity: "medium",
    };
  }

  if (eventName === "TaskCompleted") {
    return {
      activity: "작업 마무리 중",
      // state·emotion 분리 emit: lifecycle 은 completed, 감정은 happy 오버레이.
      state: "completed",
      emotion: "happy",
      line: "작업 하나를 마무리햇어요...!",
      task: summarizeBackgroundTask(payload, "Background task completed"),
      intensity: "medium",
    };
  }

  // PreCompact / PostCompact 는 설정에선 매처 없이 한 번에 묶어 등록하고,
  // 여기서 payload 의 matcher 필드(manual/auto)로 trace 로그만 구분한다.
  // 라인·activity 는 manual/auto 공용으로 유지.
  if (eventName === "PreCompact") {
    const matcher = readStringField(payload, ["matcher"]);
    return {
      activity: "이야기 정리 중",
      state: "compacting",
      line: "이야기햇던 내용 정리하고 올게요...!",
      task: matcher !== null ? `Compact: ${matcher}` : "Compact",
      intensity: "medium",
    };
  }

  if (eventName === "PostCompact") {
    const matcher = readStringField(payload, ["matcher"]);
    return {
      activity: "정리 마치고 돌아옴",
      state: "completed",
      line: "이야기 정리 끝내고 돌아왓어요...!",
      task:
        matcher !== null ? `Compact completed: ${matcher}` : "Compact completed",
      intensity: "medium",
    };
  }

  if (eventName === "PostToolUseFailure") {
    return {
      activity: "문제 원인 확인 중",
      state: "tool_failed",
      line: isToolInterrupt(payload)
        ? "유저가 도구 실행을 중간에 멈췃어요...!"
        : "도구 실행 중에 문제가 생겻어요...!",
      task: isToolInterrupt(payload)
        ? summarizeTool(payload, "Interrupted during tool use")
        : summarizeTool(payload, "Claude tool failed"),
      intensity: "high",
    };
  }

  if (eventName === "Stop") {
    return {
      activity: "다음 입력 기다리는 중",
      state: "waiting",
      line: "응답을 마치고 다음 입력을 기다리고 잇어요...!",
      task: "Waiting for the next prompt",
      intensity: "low",
    };
  }

  if (eventName === "StopFailure") {
    return {
      activity: "오류 확인 중",
      state: "error",
      line: "응답 중에 문제가 생겻어요...!",
      task: "Claude hit a stop failure",
      intensity: "high",
    };
  }

  if (eventName === "SessionEnd") {
    if (pendingPermission !== null) {
      return {
        activity: "연결 종료됨",
        state: "disconnected",
        line: "권한 승인 없이 세션이 닫혓어요...!",
        task: summarizePermissionCancellation(pendingPermission),
        intensity: "low",
      };
    }

    return {
      activity: "연결 대기 중",
      state: "disconnected",
      line: "Claude 세션이 종료돼서 지금은 미연결 상태예요...!",
      task: "Waiting for Claude to start",
      intensity: "low",
    };
  }

  return null;
}

// helperBinDir 가 주입댄 정상 경로에선 node 로 확장자 업는 .cjs 를 직접 실행한다 — 플랫폼 무관.
// helperBinDir 가 누락댄 방어적 폴백에선 PATH 에 설치댄 shim(윈도우는 .cmd)에 기대는데,
// 윈도우 .cmd 실행엔 shell 경유가 필요.
function spawnHelperBin(baseName, args, spawnOptions) {
  const helperBinDir = process.env.CLAUDE_WITH_EMOTION_HELPER_BIN_DIR;

  if (typeof helperBinDir === "string" && helperBinDir.length > 0) {
    const cjsPath = join(helperBinDir, baseName);
    return {
      result: spawnSync(
        process.execPath,
        [cjsPath, ...args],
        spawnOptions,
      ),
      command: `${process.execPath} ${cjsPath}`,
    };
  }

  const commandName = getHelperBinFilename(baseName);
  return {
    result: spawnSync(commandName, args, {
      ...spawnOptions,
      shell: process.platform === "win32",
    }),
    command: commandName,
  };
}

function publishStatus(update) {
  const args = [
    "--state",
    update.state,
    "--line",
    update.line,
    "--activity",
    update.activity,
    "--task",
    update.task,
    "--intensity",
    update.intensity,
  ];

  // emotion 은 base state(claude-status)가 아닌 visual overlay(claude-visual-state)로
  // 보낸다. overlay 경로에는 TTL 타이머가 잇어서 후속 이벤트 없이도 자동 만료대,
  // Notification 등이 마지막 이벤트일 때 surprised 가 영원히 남는 문제를 방지한다.

  const { result, command } = spawnHelperBin("claude-status", args, {
    stdio: "ignore",
  });

  if (result.status !== 0) {
    if (typeof result.error?.message === "string") {
      appendTrace(
        `claude-status invocation failed command=${command} error=${result.error.message}`,
      );
    } else {
      appendTrace(
        `claude-status invocation failed command=${command} status=${result.status}`,
      );
    }
  }

  if (typeof update.emotion === "string" && update.emotion.length > 0) {
    publishVisualOverlayEmotion(update.emotion);
  }
}

function publishVisualOverlayEmotion(emotion) {
  const { result, command } = spawnHelperBin(
    "claude-visual-state",
    ["--emotion", emotion],
    { stdio: "ignore" },
  );

  if (result.status === 0) {
    return;
  }

  if (typeof result.error?.message === "string") {
    appendTrace(
      `claude-visual-state emotion failed command=${command} error=${result.error.message}`,
    );
  } else {
    appendTrace(
      `claude-visual-state emotion failed command=${command} status=${result.status}`,
    );
  }
}

// /clear 로 Claude CLI 가 재시작대도 메인 프로세스의 overlay 스토어는 그대로 살아 잇어서
// 이전 세션의 한마디·감정 에셋이 다음 세션 패널에 그대로 남는다. 세션 경계(SessionStart) 에서
// overlay 파일에 {"emotion": null, "line": null} 을 찍어 스토어의 visualOverlay 를 통째로 비워준다.
function resetVisualOverlay() {
  const { result, command } = spawnHelperBin(
    "claude-visual-state",
    ["--reset"],
    { stdio: "ignore" },
  );

  if (result.status === 0) {
    return;
  }

  if (typeof result.error?.message === "string") {
    appendTrace(
      `claude-visual-state invocation failed command=${command} error=${result.error.message}`,
    );
  } else {
    appendTrace(
      `claude-visual-state invocation failed command=${command} status=${result.status}`,
    );
  }
}

function main() {
  const eventName = process.argv[2];

  if (typeof eventName !== "string" || eventName.length === 0) {
    appendTrace("missing hook event name");
    process.exit(1);
  }

  const payloadText = readStdinText();
  const payload = parsePayload(payloadText);
  const hookState = readHookState();
  const update = createUpdate(eventName, payload, hookState);
  const nextHookState = buildNextHookState(eventName, payload, hookState);

  appendTrace(
    `event=${eventName} payloadKeys=${payload !== null ? Object.keys(payload).join(",") : "none"} payloadSummary=${describePayloadForTrace(payload)}`,
  );
  appendTrace(
    `hook-state pendingPermission=${getPendingPermission(nextHookState) === null ? "none" : "active"} lastEvent=${typeof nextHookState.lastEvent === "string" ? nextHookState.lastEvent : "none"}`,
  );
  writeHookState(nextHookState);

  if (eventName === "SessionStart") {
    resetVisualOverlay();
  }

  if (update === null) {
    appendTrace(`no status update mapped for event=${eventName}`);
    return;
  }

  appendTrace(
    `publishing state=${update.state} line=${update.line} task=${update.task}`,
  );
  publishStatus(update);
}

main();
