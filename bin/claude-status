#!/usr/bin/env node

const fs = require('node:fs');

function appendTrace(message) {
  const traceFilePath = process.env.CLAUDE_WITH_EMOTION_TRACE_FILE;

  if (typeof traceFilePath !== 'string' || traceFilePath.length === 0) {
    return;
  }

  const line = `[${new Date().toISOString()}] [claude-status-helper] ${message}\n`;

  try {
    fs.appendFileSync(traceFilePath, line, 'utf8');
  } catch {
    // Ignore trace write failures inside the terminal helper.
  }
}

function parseArgs(argv) {
  if (argv.length === 1 && argv[0].trim().startsWith('{')) {
    return JSON.parse(argv[0]);
  }

  const result = {};

  for (let index = 0; index < argv.length; index += 2) {
    const key = argv[index];
    const value = argv[index + 1];

    if (typeof key !== 'string' || !key.startsWith('--') || value === undefined) {
      continue;
    }

    if (key === '--state') {
      result.state = value;
    } else if (key === '--emotion') {
      result.emotion = value;
    } else if (key === '--line') {
      result.line = value;
    } else if (key === '--task') {
      result.currentTask = value;
    } else if (key === '--duration-ms') {
      const parsed = Number(value);

      if (!Number.isNaN(parsed)) {
        result.durationMs = parsed;
      }
    } else if (key === '--intensity') {
      result.intensity = value;
    }
  }

  return result;
}

function collectAvailableVisualOptions(catalog) {
  const states = [];
  const emotions = [];
  const seenStates = new Set();
  const seenEmotions = new Set();

  if (!catalog || !Array.isArray(catalog.mappings)) {
    return { states, emotions };
  }

  for (const mapping of catalog.mappings) {
    if (
      typeof mapping === 'object' &&
      mapping !== null &&
      typeof mapping.state === 'string' &&
      !seenStates.has(mapping.state)
    ) {
      seenStates.add(mapping.state);
      states.push(mapping.state);
    }

    if (
      typeof mapping === 'object' &&
      mapping !== null &&
      typeof mapping.emotion === 'string' &&
      mapping.emotion !== 'neutral' &&
      !seenEmotions.has(mapping.emotion)
    ) {
      seenEmotions.add(mapping.emotion);
      emotions.push(mapping.emotion);
    }
  }

  return {
    states,
    emotions,
  };
}

function printAvailableVisualOptions() {
  const catalogFilePath = process.env.CLAUDE_WITH_EMOTION_VISUAL_ASSET_CATALOG_FILE;

  if (typeof catalogFilePath !== 'string' || catalogFilePath.length === 0) {
    process.stdout.write('{"states":[],"emotions":[]}\n');
    return;
  }

  try {
    const text = fs.readFileSync(catalogFilePath, 'utf8');
    const parsed = JSON.parse(text);

    process.stdout.write(
      `${JSON.stringify(collectAvailableVisualOptions(parsed))}\n`,
    );
  } catch {
    process.stdout.write('{"states":[],"emotions":[]}\n');
  }
}

function main() {
  if (process.argv.includes('--list-visual-options')) {
    printAvailableVisualOptions();
    return;
  }

  const statusFilePath = process.env.CLAUDE_WITH_EMOTION_STATUS_FILE;

  if (typeof statusFilePath !== 'string' || statusFilePath.length === 0) {
    console.error('CLAUDE_WITH_EMOTION_STATUS_FILE is not set.');
    process.exit(1);
  }

  const payload = parseArgs(process.argv.slice(2));

  if (typeof payload.state !== 'string' || typeof payload.line !== 'string') {
    console.error('Usage: claude-status --state <state> [--emotion <neutral|happy|sad|surprised>] --line <line> [--task <task>] [--duration-ms <ms>] [--intensity <low|medium|high>] [--list-visual-options]');
    process.exit(1);
  }

  appendTrace(
    `writing status state=${payload.state} emotion=${payload.emotion ?? 'none'} line=${payload.line} task=${payload.currentTask ?? ''}`,
  );
  fs.writeFileSync(statusFilePath, JSON.stringify(payload), 'utf8');
}

main();
