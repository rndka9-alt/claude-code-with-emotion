#!/usr/bin/env node

const fs = require("node:fs");
const { resolveVisualMcpRuntime } = require("./lib/claude-visual-mcp-state");

function appendTrace(message) {
  const traceFilePath = resolveVisualMcpRuntime().traceFilePath;

  if (typeof traceFilePath !== "string" || traceFilePath.length === 0) {
    return;
  }

  const line = `[${new Date().toISOString()}] [claude-visual-state-helper] ${message}\n`;

  try {
    fs.appendFileSync(traceFilePath, line, "utf8");
  } catch {
    // Ignore trace write failures inside the terminal helper.
  }
}

function parseArgs(argv) {
  if (argv.length === 1 && argv[0].trim().startsWith("{")) {
    return JSON.parse(argv[0]);
  }

  const result = {};

  for (let index = 0; index < argv.length; index += 1) {
    const key = argv[index];

    if (typeof key !== "string" || !key.startsWith("--")) {
      continue;
    }

    if (key === "--clear-line") {
      result.line = null;
      continue;
    }

    const value = argv[index + 1];

    if (value === undefined) {
      continue;
    }

    if (key === "--emotion") {
      result.emotion = value === "neutral" ? null : value;
      index += 1;
    } else if (key === "--line") {
      result.line = value;
      index += 1;
    }
  }

  return result;
}

async function main() {
  const overlayFilePath = resolveVisualMcpRuntime().visualOverlayFilePath;

  if (typeof overlayFilePath !== "string" || overlayFilePath.length === 0) {
    console.error("CLAUDE_WITH_EMOTION_VISUAL_OVERLAY_FILE must be set.");
    process.exit(1);
  }

  const payload = parseArgs(process.argv.slice(2));

  if (
    payload === null ||
    typeof payload !== "object" ||
    (payload.emotion === undefined && payload.line === undefined)
  ) {
    console.error(
      "Usage: claude-visual-state --emotion <emotion> [--line <line>] [--clear-line]",
    );
    process.exit(1);
  }

  appendTrace(
    `writing visual overlay emotion=${payload.emotion ?? "none"} line=${payload.line ?? ""}`,
  );

  // 부분 업데이트가 기존 필드를 덮어쓰지 않도록 파일 읽고 merge 후 쓴다.
  // 두 툴이 연달아 호출될 때 레이스로 한 쪽이 씹히던 버그 방지.
  let existingPayload = {};

  try {
    if (fs.existsSync(overlayFilePath)) {
      const existingContents = fs.readFileSync(overlayFilePath, "utf8").trim();

      if (existingContents.length > 0) {
        const parsed = JSON.parse(existingContents);

        if (typeof parsed === "object" && parsed !== null) {
          existingPayload = parsed;
        }
      }
    }
  } catch {
    // 잘못된 기존 파일은 빈 상태로 취급하고 그대로 덮어쓴다.
  }

  const mergedPayload = { ...existingPayload, ...payload };

  fs.writeFileSync(overlayFilePath, JSON.stringify(mergedPayload), "utf8");
}

void main().catch((error) => {
  console.error(error instanceof Error ? error.message : String(error));
  process.exit(1);
});
